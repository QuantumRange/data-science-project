    "   \"source\": [\n",
    "    \"tmp_dir = Path(\\\"/mnt/Fast2T/data/tmp\\\")\\n\",\n",
    "    \"tmp_dir.mkdir(parents=True, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"BUCKETS = 128\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file in v5_files:\\n\",\n",
    "    \"    print(f\\\"File: {file}\\\")\\n\",\n",
    "    \"    lf = (\\n\",\n",
    "    \"        pl\\n\",\n",
    "    \"        .scan_parquet(file)\\n\",\n",
    "    \"        .select(pl.col(\\\"text\\\").str.split(' '))\\n\",\n",
    "    \"        .explode('text')\\n\",\n",
    "    \"        .group_by('text')\\n\",\n",
    "    \"        .len()\\n\",\n",
    "    \"        .filter(pl.col(\\\"len\\\") > 5)\\n\",\n",
    "    \"        .top_k(50, by=\\\"len\\\")\\n\",\n",
    "    \"        .with_columns(\\n\",\n",
    "    \"            (pl.col(\\\"text\\\").hash(seed=0) % BUCKETS).alias(\\\"bucket\\\")\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    lf.sink_parquet(pl.PartitionBy(tmp_dir, key=\\\"bucket\\\"))\"\n",
