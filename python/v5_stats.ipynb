    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"(pl.scan_parquet(v5_files)\\n\",\n",
    "    \" .select(pl.col(\\\"lang\\\"), pl.col(\\\"type\\\"))\\n\",\n",
