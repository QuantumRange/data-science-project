<div id="aiscore-plot"></div>

<script>
  import * as Plot from "@observablehq/plot";
  import * as d3 from "d3";

  // ── Config ──────────────────────────────────────────────────────────────────

  const FILL = "oklch(0.3742 0.1348 257.36 / 60%)";
  const STROKE = "oklch(0.3742 0.1348 257.36)";

  // ── DOM refs ────────────────────────────────────────────────────────────────

  const plotDiv = document.querySelector<HTMLElement>("#aiscore-plot");

  // ── Data ────────────────────────────────────────────────────────────────────

  async function loadData() {
    return d3.csv("/graph_data/test_1.csv", d3.autoType);
  }

  // ── Render ──────────────────────────────────────────────────────────────────

  async function renderPlot() {
    if (!plotDiv) {
      console.error("aiscore-plot element not found");
      return;
    }

    const rows = await loadData();

    plotDiv.innerHTML = "";
    plotDiv.append(
      Plot.plot({
        y: {
          grid: true,
          inset: 6,
          type: "symlog",
          domain: [0, 0.1],
        },
        marks: [
          Plot.boxY(rows, {
            x: "topic",
            y: "ai_topic_score",
            fill: FILL,
            stroke: STROKE,
          }),
        ],
      }),
    );
  }

  // ── Init ────────────────────────────────────────────────────────────────────

  renderPlot();
</script>
