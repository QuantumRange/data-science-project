       "                    if (col.rightAlign)\n",
       "                        classes += &quot; rightAlign&quot;\n",
       "                    if (classes.length &gt; 0)\n",
       "                        td.setAttribute(&quot;class&quot;, classes)\n",
       "                    tr.appendChild(td)\n",
       "                    let value = col.values[row]\n",
       "                    if (value.frameId !== undefined) {\n",
